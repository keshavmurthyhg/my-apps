import pythoncom
import win32com.client
import pandas as pd


def get_support_emails(limit=500):

    pythoncom.CoInitialize()

    outlook = win32com.client.Dispatch(
        "Outlook.Application"
    ).GetNamespace("MAPI")

    inbox = outlook.GetDefaultFolder(6)

    emails = []

    messages = inbox.Items
    messages.Sort("[ReceivedTime]", True)

    count = 0

    for msg in messages:

        try:

            if msg.Class != 43:
                continue

            emails.append({

                "Date Received":
                    str(msg.ReceivedTime),

                "Name":
                    str(msg.SenderName),

                "Subject":
                    str(msg.Subject),

                "Importance":
                    {
                        0: "Low",
                        1: "Normal",
                        2: "High"
                    }.get(
                        msg.Importance,
                        "Normal"
                    ),

                "Categories":
                    str(msg.Categories or "")
            })

            count += 1

            if count >= limit:
                break

        except Exception:
            continue

    return pd.DataFrame(emails)


